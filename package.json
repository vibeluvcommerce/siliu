{
  "name": "siliu",
  "version": "2.0.0",
  "description": "Siliu Browser with AI Copilot (with Widevine DRM support)",
  "main": "src/app.js",
  "scripts": {
    "start": "electron . --no-sandbox",
    "dev": "electron . --dev --no-sandbox",
    "test": "jest",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win zip",
    "dist:win:portable": "electron-builder --win portable",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.siliu.browser",
    "productName": "Siliu Browser",
    "icon": "assets/app",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/puppeteer/**/*",
      "**/node_modules/puppeteer-core/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "electronDist": "node_modules/electron/dist",
    "extraResources": [],
    "files": [
      "src/**/*",
      "public/**/*",
      "node_modules/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "publisherName": "Siliu Team",
      "verifyUpdateCodeSignature": false
    },
    "forceCodeSigning": false,
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Siliu Browser",
      "uninstallDisplayName": "Siliu Browser"
    },
    "portable": {
      "artifactName": "${productName}-${version}-Portable.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "icon": "assets/app.icns"
    },
    "dmg": {
      "title": "${productName} ${version}",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "tar.gz",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Network",
      "icon": "assets/app.png"
    }
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@phosphor-icons/web": "^2.1.2",
    "axios": "^1.13.6",
    "chokidar": "^3.6.0",
    "csv-writer": "^1.6.0",
    "exceljs": "^4.4.0",
    "form-data": "^4.0.5",
    "js-yaml": "^4.1.1",
    "koffi": "^2.15.2",
    "puppeteer": "^21.5.2",
    "puppeteer-core": "^24.37.3",
    "uuid": "^9.0.1",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "electron": "github:castlabs/electron-releases#v41.0.0-beta.7+wvcus",
    "electron-builder": "^24.9.1",
    "jest": "^29.7.0"
  },
  "author": "Siliu Team",
  "license": "MIT"
}

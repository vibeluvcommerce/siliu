{
  "name": "siliu",
  "version": "2.0.0",
  "description": "Siliu Browser with AI Copilot (with Widevine DRM support)",
  "main": "src/app.js",
  "scripts": {
    "start": "electron . --no-sandbox",
    "dev": "electron . --dev --no-sandbox",
    "test": "jest",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win zip",
    "dist:win:portable": "electron-builder --win portable",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.siliu.browser",
    "productName": "Siliu Browser",
    "directories": {
      "output": "dist"
    },
    "extraResources": [],
    "files": [
      "src/**/*",
      "public/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "publisherName": "Siliu Team",
      "verifyUpdateCodeSignature": false
    },
    "forceCodeSigning": false,
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Siliu Browser",
      "uninstallDisplayName": "Siliu Browser"
    },
    "portable": {
      "artifactName": "${productName}-${version}-Portable.${ext}"
    }
  },
  "dependencies": {
    "axios": "^1.13.6",
    "form-data": "^4.0.5",
    "puppeteer-core": "^24.37.3",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "electron": "^26.6.10",
    "electron-builder": "^24.9.1",
    "jest": "^29.7.0"
  },
  "author": "Siliu Team",
  "license": "MIT"
}

// config.example.json - 完整配置示例（含 Tailscale）
{
  "ai": {
    // 模式: "openclaw" | "kimi"
    "mode": "openclaw",
    
    "openclaw": {
      // 云端 OpenClaw 地址
      "url": "ws://100.64.1.2:18789",
      "token": "your-gateway-token",
      "sessionKey": "agent:window:main",
      "isCloud": true
    }
  },
  
  "visual": {
    // 截图配置
    "maxWidth": 1280,
    "quality": 80,
    "format": "jpeg",
    
    // 传输模式:
    // - "file": 本地文件（OpenClaw 和 Siliu 同一台机器）
    // - "upload": 上传到公共图床（不推荐）
    // - "server": 本地 HTTP 服务（Tailscale/内网穿透）⭐ 推荐
    "transferMode": "server",
    
    // HTTP 服务配置
    "serverPort": 0,  // 0 = 随机端口
    
    // Tailscale IP（通过 `tailscale ip -4` 获取）
    // 云端 OpenClaw 将通过此 IP 访问本地截图服务
    "tailscaleIp": "100.64.1.3"
  },
  
  "tempDir": "/tmp/siliu-screenshots"
}

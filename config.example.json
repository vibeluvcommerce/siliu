// config.example.json - Siliu 完整配置示例
// 将此文件复制到 ~/.siliu/config.json (Windows: %USERPROFILE%\.siliu\config.json)

{
  "version": 1,
  
  // 服务模式: "cloud" (Kimi/MiniMax) | "local" (OpenClaw)
  "serviceType": "cloud",
  
  // 云端 AI 配置 (Kimi)
  "cloud": {
    "apiEndpoint": "https://api.moonshot.cn/v1",
    "apiKey": "sk-your-kimi-api-key",
    "model": "kimi-k2.5"
  },
  
  // 本地 OpenClaw 配置
  "local": {
    "url": "ws://127.0.0.1:18789",
    "token": "your-openclaw-token",
    "sessionKey": "agent:main:main"
  },
  
  // UI 配置
  "ui": {
    "theme": "system",
    "sidebarCollapsed": false,
    "devTools": false
  },
  
  // 浏览器配置
  "browser": {
    "defaultUrl": "https://www.google.com",
    "blockAds": true,
    "humanize": {
      "enabled": true,
      "minDelay": 150,
      "maxDelay": 400,
      "typeDelay": 25,
      "scrollDelay": 100
    }
  },
  
  // Copilot 配置
  "copilot": {
    "maxSteps": 30,
    "autoStart": false,
    "enableThinking": true,
    "confirmationMode": "auto"
  }
}

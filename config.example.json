// config.example.json - Siliu 配置示例
// 将此文件复制到 ~/.siliu/config.json (Windows: %USERPROFILE%\.siliu\config.json)

{
  "version": 1,
  
  // ========================================
  // AI 后端配置（三选一）
  // ========================================
  
  // 选项 1: Kimi Code 订阅 ⭐⭐⭐⭐ 推荐
  // 特点：专为编码优化，响应更快，支持长上下文
  "serviceType": "cloud",
  "cloud": {
    "apiEndpoint": "https://api.kimi.com/coding/v1",
    "apiKey": "sk-your-kimi-code-api-key",
    "model": "k2p5",
    "temperature": 0.7,
    "maxTokens": 4096
  },
  
  // 选项 2: Moonshot Kimi API ⭐⭐⭐
  // 特点：标准 Kimi API，通用场景
  // "serviceType": "cloud",
  // "cloud": {
  //   "apiEndpoint": "https://api.moonshot.cn/v1",
  //   "apiKey": "sk-your-moonshot-api-key",
  //   "model": "kimi-k2.5"
  // },
  
  // 选项 3: 智谱 GLM-4.6V ⭐⭐⭐⭐⭐ 推荐（国内最佳视觉模型）
  // 特点：原生多模态视觉，国内访问快，无需 MCP，识别准确
  // "serviceType": "cloud",
  // "cloud": {
  //   "apiEndpoint": "https://open.bigmodel.cn/api/paas/v4",
  //   "apiKey": "your-zhipu-api-key",
  //   "model": "glm-4.6v"
  // },
  
  // 选项 4: OpenClaw 本地网关 ⭐⭐
  // 特点：自托管，隐私优先，需要额外部署
  // "serviceType": "local",
  // "local": {
  //   "url": "ws://127.0.0.1:18789",
  //   "token": "your-openclaw-token",
  //   "sessionKey": "agent:main:main"
  // },
  
  // ========================================
  // UI 配置
  // ========================================
  "ui": {
    "theme": "system",
    "sidebarCollapsed": false,
    "devTools": false
  },
  
  // ========================================
  // 浏览器配置
  // ========================================
  "browser": {
    "defaultUrl": "https://www.google.com",
    "blockAds": true,
    "humanize": {
      "enabled": true,
      "minDelay": 150,
      "maxDelay": 400,
      "typeDelay": 25,
      "scrollDelay": 100
    }
  },
  
  // ========================================
  // Copilot 配置
  // ========================================
  "copilot": {
    "maxSteps": 30,
    "autoStart": false,
    "enableThinking": true,
    "confirmationMode": "auto"
  }
}
